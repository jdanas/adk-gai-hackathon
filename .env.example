APP_NAME=FlowMind API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
APP_DEBUG=false

GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=asia-southeast1
VERTEX_AI_LOCATION=asia-southeast1
VERTEX_AI_MODEL=gemini-2.5-pro
GOOGLE_API_KEY=

ALLOYDB_HOST=127.0.0.1
ALLOYDB_PORT=5432
ALLOYDB_DATABASE=flowmind
ALLOYDB_USER=postgres
ALLOYDB_PASSWORD=change-me
ALLOYDB_SSL=require
ALLOYDB_DSN=postgresql://postgres:change-me@127.0.0.1:5432/flowmind?ssl=require
ALLOYDB_INSTANCE_URI=projects/your-gcp-project-id/locations/asia-southeast1/clusters/your-cluster/instances/your-instance
ALLOYDB_IP_TYPE=PRIVATE
ALLOYDB_ENABLE_IAM_AUTH=false

NOTES_EMBEDDING_DIM=768
FLOWMIND_NOTES_DEFAULT_LIMIT=5

MCP_SERVER_NAME=flowmind-mcp
MCP_TRANSPORT=streamable-http
