APP_NAME=FlowMind API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
APP_DEBUG=true

GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=asia-southeast1
VERTEX_AI_LOCATION=asia-southeast1
VERTEX_AI_MODEL=gemini-2.5-pro
GOOGLE_API_KEY=

ALLOYDB_HOST=127.0.0.1
ALLOYDB_PORT=5432
ALLOYDB_DATABASE=flowmind
ALLOYDB_USER=postgres
ALLOYDB_PASSWORD=postgres
ALLOYDB_SSL=disable
ALLOYDB_DSN=postgresql://postgres:postgres@127.0.0.1:5432/flowmind
ALLOYDB_INSTANCE_URI=
ALLOYDB_IP_TYPE=PRIVATE
ALLOYDB_ENABLE_IAM_AUTH=false

NOTES_EMBEDDING_DIM=768
FLOWMIND_NOTES_DEFAULT_LIMIT=5
FLOWMIND_ENABLE_ADK=false
FLOWMIND_ENABLE_MCP=false

MCP_SERVER_NAME=flowmind-mcp
MCP_TRANSPORT=streamable-http
